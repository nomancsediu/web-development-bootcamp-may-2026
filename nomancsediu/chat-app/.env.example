# Local docker development example
# Copy this file to .env and fill your values.

MONGO_URI=mongodb://mongodb:27017/Chatappmicroserviceapp
REDIS_URL=redis://redis:6379
RABBITMQ_HOST=rabbitmq
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
JWT_SECRET=your_jwt_secret
MAIL_USER=your_email@example.com
MAIL_PASSWORD=your_email_password
NEXT_PUBLIC_USER_SERVICE=http://localhost:5000
NEXT_PUBLIC_CHAT_SERVICE=http://localhost:5002
