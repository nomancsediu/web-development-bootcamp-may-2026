# Production Environment Variables
# Set these in your Dokploy deployment

# Database (Use MongoDB Atlas or external MongoDB)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp?retryWrites=true&w=majority

# Redis (Use Upstash Redis or external Redis)
REDIS_URL=rediss://default:password@redis-host:6379

# RabbitMQ (Use CloudAMQP or external RabbitMQ)
RABBITMQ_URL=amqp://username:password@rabbitmq-host:5672
RABBITMQ_HOST=rabbitmq-host
RABBITMQ_USERNAME=username
RABBITMQ_PASSWORD=password

# Cloudinary (Required for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# JWT Secret (Generate a strong secret)
JWT_SECRET=your-super-secure-jwt-secret-key-here

# Email (Use Gmail App Password or SMTP service)
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Service URLs (Update with your Dokploy domain)
NEXT_PUBLIC_USER_SERVICE=https://your-domain.com
NEXT_PUBLIC_CHAT_SERVICE=https://your-domain.com
USER_SERVICE=http://user:5000
