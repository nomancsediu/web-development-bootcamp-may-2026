# Production Environment Variables for Dokploy
# Copy these to your Dokploy environment variables section

# Database - Use MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp?retryWrites=true&w=majority

# Redis - Use Upstash Redis
REDIS_URL=rediss://default:password@redis-host:6379

# RabbitMQ - Use CloudAMQP
RABBITMQ_URL=amqp://username:password@rabbitmq-host:5672
RABBITMQ_HOST=rabbitmq-host.cloudamqp.com
RABBITMQ_USERNAME=your-username
RABBITMQ_PASSWORD=your-password

# Cloudinary - For file uploads
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# JWT Secret - Generate a strong secret
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-32-characters

# Email - Use Gmail with App Password
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# Service URLs - Update with your Dokploy domain
NEXT_PUBLIC_USER_SERVICE=https://your-domain.com
NEXT_PUBLIC_CHAT_SERVICE=https://your-domain.com
USER_SERVICE=http://user:5000

# Optional: Node Environment
NODE_ENV=production